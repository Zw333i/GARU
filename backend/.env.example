# Supabase Configuration
# Get service role key from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_service_role_key

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True
ENVIRONMENT=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
# Optional: comma-separated allowlist for multiple frontend domains
# Example: FRONTEND_URLS=https://garu.vercel.app,https://garu-git-main-yourteam.vercel.app
FRONTEND_URLS=

# NBA API Configuration
NBA_API_TIMEOUT=30
